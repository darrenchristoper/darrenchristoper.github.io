---
import HeaderPage from "../component/header";
import FooterPage from "../component/FooterPage";
---
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/dc.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>About — Darren Christoper</title>
    <meta name="description" content="About Darren Christoper — Full Stack Software Engineer with M.A.S. in Computer Science from IIT. Experience in cloud infrastructure, AI/ML pipelines, and embedded systems." />
    <meta property="og:title" content="About — Darren Christoper" />
    <meta property="og:description" content="Full Stack Software Engineer with M.A.S. from IIT. Cloud infrastructure, AI/ML, Angular, Laravel, and Robotics." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://darrenchristoper.github.io/about" />
</head>
<body style="margin: 0; padding: 0; background: #fff;">
<HeaderPage client:load active="about" />

<div class="animate-fade animate-once animate-duration-[1000ms] animate-ease-out animate-fill-forwards">
<section style="background: #fff; padding: 100px 22px; font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', Arial, sans-serif;">
    <div style="max-width: 692px; margin: 0 auto;">
        <h2 style="font-size: clamp(40px, 6vw, 64px); font-weight: 700; color: #1d1d1f; letter-spacing: -0.005em; line-height: 1.05; margin-bottom: 32px; margin-top: 0;">
            About Me
        </h2>
        <div style="font-size: 19px; line-height: 1.7; color: #1d1d1f; letter-spacing: -0.01em;">
            <p style="margin: 0 0 24px;">
                I'm <strong>Darren Christoper</strong> — a Full Stack Software Engineer based in Chicago, IL with a Master's in Computer Science from Illinois Institute of Technology. I have hands-on experience in Full Stack Development, System Scalability, and Cloud Infrastructure (AWS/GCP), working across Laravel, Angular, Ionic, Python, and more.
            </p>
            <p style="margin: 0 0 24px; color: #6e6e73;">
                Most recently I served as a Research Assistant at IIT, building scalable web applications, cloud-native deployments on GCP, and AI/ML pipelines using BERT and CNN models. I'm currently working on a Robotics &amp; Embedded Systems project at Afila Labs — developing a robotic solution for sewer pipeline inspection using LiDAR sensors on a Jetson Nano Orin platform.
            </p>
            <p style="margin: 0; color: #6e6e73;">
                Outside of work, I enjoy reading about technology, finance &amp; business. Feel free to connect — I'd love to learn more about you.
            </p>
        </div>
        <div style="margin-top: 44px; display: flex; gap: 16px; flex-wrap: wrap;">
            <a
                href="/history"
                style="display: inline-flex; align-items: center; padding: 12px 24px; font-size: 17px; font-weight: 400; color: #fff; background: #0071e3; border-radius: 980px; text-decoration: none; letter-spacing: -0.01em; transition: background 0.2s;"
                onmouseover="this.style.background='#0077ed'"
                onmouseout="this.style.background='#0071e3'"
            >
                View My Journey
            </a>
            <a
                href="/contact"
                style="display: inline-flex; align-items: center; padding: 12px 24px; font-size: 17px; font-weight: 400; color: '#1d1d1f'; background: transparent; border: 1px solid rgba(0,0,0,0.22); border-radius: 980px; text-decoration: none; letter-spacing: -0.01em; transition: background 0.2s; color: #1d1d1f;"
                onmouseover="this.style.background='rgba(0,0,0,0.06)'"
                onmouseout="this.style.background='transparent'"
            >
                Get in Touch
            </a>
        </div>
    </div>
</section>
</div>

<FooterPage client:load />
</body>
