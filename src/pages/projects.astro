---
import HeaderPage from "../component/header";
import FooterPage from "../component/FooterPage";

const projects = [
    {
        title: "Sewer Pipeline Inspection Robot",
        company: "Afila Labs",
        period: "Jan 2026 – Present",
        description: "Developing an autonomous robotic solution for sewer infrastructure inspection. Integrates LiDAR sensors with an NVIDIA Jetson Nano Orin platform to map pipeline interiors and detect structural anomalies in real-time.",
        tags: ["Python", "ROS 2", "LiDAR", "Jetson Nano Orin", "Embedded Systems", "Computer Vision"],
        accentColor: "#0071e3",
        label: "Afila Labs",
    },
    {
        title: "AI/ML Research Platform",
        company: "Illinois Institute of Technology",
        period: "Oct 2023 – Aug 2025",
        description: "Built scalable web applications and cloud-native deployments on GCP. Developed AI/ML pipelines processing large datasets using BERT, CNN, Vision Transformer, and MobileNet models. Implemented serverless backends with AWS Lambda and automated CI/CD pipelines.",
        tags: ["Python", "BERT", "CNN", "Vision Transformer", "GCP", "AWS Lambda", "Angular", "Laravel", "CI/CD"],
        accentColor: "#bf5af2",
        label: "IIT",
    },
    {
        title: "Hoki Distribution Platform",
        company: "PT Hoki Distribution Niaga",
        period: "Jul 2022 – Jul 2023",
        description: "Developed a full-stack distribution management platform for a high-traffic FMCG business. Built a cross-platform mobile app with Ionic, engineered scalable backend features with Laravel and PHP, and integrated legacy systems for real-time inventory and order management.",
        tags: ["Angular", "Laravel", "PHP", "Ionic", "TypeScript", "MySQL", "REST API"],
        accentColor: "#34c759",
        label: "PT Hoki",
    },
];
---

<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/dc.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Projects — Darren Christoper</title>
    <meta name="description" content="Projects by Darren Christoper — full-stack web platforms, AI/ML research pipelines, and robotics embedded systems." />
    <meta property="og:title" content="Projects — Darren Christoper" />
    <meta property="og:description" content="Full-stack web platforms, AI/ML research pipelines, and robotics embedded systems." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://darrenchristoper.github.io/projects" />
</head>

<body style="margin: 0; padding: 0; background: #fff;">
<HeaderPage client:load active="projects" />

<div class="animate-fade animate-once animate-duration-[1000ms] animate-ease-out animate-fill-forwards">
<section style="background: #fff; padding: 100px 22px; font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', Arial, sans-serif;">
    <div style="max-width: 980px; margin: 0 auto;">
        <h2 style="font-size: clamp(40px, 6vw, 64px); font-weight: 700; color: #1d1d1f; letter-spacing: -0.005em; line-height: 1.05; margin-bottom: 12px; margin-top: 0;">
            Featured Projects
        </h2>
        <p style="font-size: 19px; color: #6e6e73; margin-bottom: 64px; margin-top: 0; letter-spacing: -0.01em;">
            A selection of work from my professional experience and research.
        </p>

        <div id="project-cards" style="display: flex; flex-direction: column; gap: 20px; max-width: 780px;">
            {projects.map((p, idx) => (
                <div data-parallax-card={idx} style="background: #fff; border: 1px solid rgba(0,0,0,0.1); border-radius: 20px; padding: 40px 36px; will-change: transform; transition: box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 8px 32px rgba(0,0,0,0.1)'" onmouseout="this.style.boxShadow='none'">
                    <div style="display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 12px; margin-bottom: 16px;">
                        <div>
                            <h3 style="font-size: 21px; font-weight: 600; color: #1d1d1f; letter-spacing: -0.022em; margin: 0 0 4px;">{p.title}</h3>
                            <p style="font-size: 13px; color: #6e6e73; margin: 0; letter-spacing: -0.01em;">{p.company} · {p.period}</p>
                        </div>
                        <span style={`display: inline-flex; align-items: center; gap: 6px; padding: 4px 12px; font-size: 12px; font-weight: 600; border-radius: 980px; background: ${p.accentColor}18; color: ${p.accentColor};`}>
                            <span style={`width: 6px; height: 6px; border-radius: 50%; background: ${p.accentColor}; flex-shrink: 0;`}></span>
                            {p.label}
                        </span>
                    </div>
                    <p style="font-size: 17px; line-height: 1.7; color: #6e6e73; margin: 0 0 24px; letter-spacing: -0.01em;">{p.description}</p>
                    <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                        {p.tags.map((tag) => (
                            <span style="padding: 5px 12px; font-size: 12px; font-weight: 500; color: '#6e6e73'; background: '#f5f5f7'; border-radius: 980px; color: #6e6e73; background: #f5f5f7;">{tag}</span>
                        ))}
                    </div>
                </div>
            ))}
        </div>

        <div style="margin-top: 52px; display: flex; gap: 16px; flex-wrap: wrap;">
            <a
                href="/history"
                style="display: inline-flex; align-items: center; padding: 12px 24px; font-size: 17px; font-weight: 400; color: #fff; background: #0071e3; border-radius: 980px; text-decoration: none; letter-spacing: -0.01em; transition: background 0.2s;"
                onmouseover="this.style.background='#0077ed'"
                onmouseout="this.style.background='#0071e3'"
            >
                View Full Journey
            </a>
            <a
                href="/contact"
                style="display: inline-flex; align-items: center; padding: 12px 24px; font-size: 17px; font-weight: 400; color: #1d1d1f; background: transparent; border: 1px solid rgba(0,0,0,0.22); border-radius: 980px; text-decoration: none; letter-spacing: -0.01em; transition: background 0.2s;"
                onmouseover="this.style.background='rgba(0,0,0,0.06)'"
                onmouseout="this.style.background='transparent'"
            >
                Get in Touch
            </a>
        </div>
    </div>
</section>
</div>

<FooterPage client:load />
</body>

<script>
(function () {
    const speeds = [0.05, 0.03, 0.07];
    const cards = Array.from(document.querySelectorAll('[data-parallax-card]'));
    let raf = 0;

    function update() {
        cards.forEach(function (card, i) {
            const el = card as HTMLElement;
            const rect = el.getBoundingClientRect();
            const center = (rect.top + rect.height / 2) - window.innerHeight / 2;
            el.style.transform = 'translateY(' + (center * (speeds[i] ?? 0.04) * -1) + 'px)';
        });
        raf = 0;
    }

    window.addEventListener('scroll', function () {
        if (!raf) raf = requestAnimationFrame(update);
    }, { passive: true });

    update();
})();
</script>
