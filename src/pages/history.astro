---
import LineHistory from "../component/LineHistory";
import HeaderPage from "../component/header";
import FooterPage from "../component/FooterPage";
import Jumbotron from "../astropage/jumbotronhistory.astro";
---
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/dc.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Journey — Darren Christoper</title>
    <meta name="description" content="Darren Christoper's professional journey — from XJTLU & University of Liverpool to IIT, robotics research at Afila Labs, and full-stack engineering." />
    <meta property="og:title" content="Journey — Darren Christoper" />
    <meta property="og:description" content="Timeline of Darren Christoper's education, work experience, and milestones in software engineering and research." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://darrenchristoper.github.io/history" />
</head>

<body style="margin: 0; padding: 0; background: #000;">
<HeaderPage client:load active="history" />
<Jumbotron />
<LineHistory client:load />
<FooterPage client:load />
</body>
